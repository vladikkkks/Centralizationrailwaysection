<Window x:Class="DncApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="АРМ ДНЦ - Рівненська дитяча залізниця (Тренажер МПЦ)" Height="760" Width="1200"
        Background="#0A0A0C">
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#161b22" BorderBrush="#334155" BorderThickness="0,0,2,0" Panel.ZIndex="10">
            <StackPanel>
                <StackPanel Margin="15,20,15,10">
                    <TextBlock x:Name="ClockText" Text="00:00:00" Foreground="#10b981" FontSize="26" FontWeight="Bold" FontFamily="Consolas" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                    <TextBlock Text="ПУЛЬТ МПЦ" Foreground="#94a3b8" FontSize="15" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                    
                    <Button x:Name="BtnStationCentral" Content="СТАНЦІЯ ЦЕНТРАЛЬНА" Height="38" Margin="0,0,0,8" Background="#334155" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="SwitchStation_Click"/>
                    <Button x:Name="BtnStationOzerna" Content="СТАНЦІЯ ОЗЕРНА" Height="38" Margin="0,0,0,20" Background="#1e293b" Foreground="#94a3b8" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="SwitchStation_Click"/>
                    
                    <Button Content="⚠ АВАРІЙНЕ ПЕРЕКРИТТЯ" Height="45" Background="#dc2626" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="BtnEmergencyStop_Click"/>

                    <TextBlock Text="ЖУРНАЛ ПОДІЙ ДНЦ:" Foreground="#94a3b8" FontSize="11" Margin="0,20,0,5"/>
                    <ListBox x:Name="LogListBox" Height="200" Background="#0f172a" Foreground="#10b981" FontFamily="Consolas" FontSize="11" BorderBrush="#334155"/>
                </StackPanel>

                <Separator Background="#334155" Margin="15,5"/>

                <StackPanel Margin="15,10,15,15" Background="#1e293b">
                    <TextBlock Text="ГЕНЕРАЦІЯ РУХОМОГО СКЛАДУ" Foreground="#38bdf8" FontSize="13" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,15,0,5"/>
                    <TextBlock Text="(Керування здійснюється кліком по поїзду)" Foreground="#64748b" FontSize="10" TextAlignment="Center" Margin="0,0,0,15"/>
                    
                    <Button Content="+ НА СТ. ЦЕНТРАЛЬНА" Height="32" Margin="15,0,15,8" Background="#475569" Foreground="White" BorderThickness="0" Cursor="Hand" Click="BtnAddTrainCentral_Click"/>
                    <Button Content="+ НА СТ. ОЗЕРНА" Height="32" Margin="15,0,15,15" Background="#475569" Foreground="White" BorderThickness="0" Cursor="Hand" Click="BtnAddTrainOzerna_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1" Margin="20">
            
            <Canvas x:Name="CentralCanvas" Visibility="Visible">
                <TextBlock Text="СТАНЦІЯ ЦЕНТРАЛЬНА" Foreground="#334155" FontSize="32" FontWeight="Bold" Canvas.Left="20" Canvas.Top="20"/>
                
                <Line X1="45" Y1="285" X2="45" Y2="315" Stroke="#dc2626" StrokeThickness="6"/>
                <Line X1="45" Y1="165" X2="45" Y2="195" Stroke="#dc2626" StrokeThickness="6"/>
                
                <Line X1="50" Y1="300" X2="700" Y2="300" Stroke="#475569" StrokeThickness="10"/>
                <TextBlock Text="2П (Головна)" Foreground="#64748b" FontSize="14" FontWeight="Bold" Canvas.Left="350" Canvas.Top="315"/>
                
                <Line X1="50" Y1="180" X2="600" Y2="180" Stroke="#475569" StrokeThickness="10"/>
                <TextBlock Text="1П (Бокова)" Foreground="#64748b" FontSize="14" FontWeight="Bold" Canvas.Left="350" Canvas.Top="150"/>
                
                <Line X1="600" Y1="180" X2="700" Y2="300" Stroke="#475569" StrokeThickness="10"/>
                <Line x:Name="CentralSwitch" X1="700" Y1="300" X2="800" Y2="300" Stroke="#e2e8f0" StrokeThickness="10" Cursor="Hand" MouseLeftButtonDown="CentralSwitch_Click" MouseRightButtonDown="Switch_RightClick"/>
                <TextBlock Text="1" Foreground="#FFF" FontWeight="Bold" Canvas.Left="750" Canvas.Top="320"/>
                <Line X1="800" Y1="300" X2="1050" Y2="300" Stroke="#475569" StrokeThickness="10"/>
                
                <Line X1="830" Y1="310" X2="830" Y2="350" Stroke="#64748b" StrokeThickness="4"/>
                <Ellipse x:Name="SignalCentralCh" Canvas.Left="820" Canvas.Top="300" Width="20" Height="20" Fill="Red" Stroke="#0f172a" StrokeThickness="3" Cursor="Hand" MouseLeftButtonDown="Signal_Click">
                    <Ellipse.ContextMenu><ContextMenu><MenuItem Header="Зелений (на 2П)" Click="SignalCentralCh_SetGreen"/><MenuItem Header="Жовтий (на 1П)" Click="SignalCentralCh_SetYellow"/><MenuItem Header="Перекрити" Click="SignalCentralCh_SetRed"/></ContextMenu></Ellipse.ContextMenu>
                </Ellipse>
                <TextBlock Text="Ч" Foreground="#FFF" FontWeight="Bold" Canvas.Left="825" Canvas.Top="355"/>
                
                <Line X1="680" Y1="310" X2="680" Y2="350" Stroke="#64748b" StrokeThickness="4"/>
                <Ellipse x:Name="SignalCentralN2" Canvas.Left="670" Canvas.Top="300" Width="20" Height="20" Fill="Red" Stroke="#0f172a" StrokeThickness="3" Cursor="Hand" MouseLeftButtonDown="Signal_Click">
                    <Ellipse.ContextMenu><ContextMenu><MenuItem Header="Відкрити" Click="SignalCentralN2_SetGreen"/><MenuItem Header="Перекрити" Click="SignalCentralN2_SetRed"/></ContextMenu></Ellipse.ContextMenu>
                </Ellipse>
                <TextBlock Text="Н2" Foreground="#FFF" FontWeight="Bold" Canvas.Left="673" Canvas.Top="355"/>
                
                <Line X1="580" Y1="190" X2="580" Y2="230" Stroke="#64748b" StrokeThickness="4"/>
                <Ellipse x:Name="SignalCentralN1" Canvas.Left="570" Canvas.Top="180" Width="20" Height="20" Fill="Red" Stroke="#0f172a" StrokeThickness="3" Cursor="Hand" MouseLeftButtonDown="Signal_Click">
                    <Ellipse.ContextMenu><ContextMenu><MenuItem Header="Відкрити" Click="SignalCentralN1_SetGreen"/><MenuItem Header="Перекрити" Click="SignalCentralN1_SetRed"/></ContextMenu></Ellipse.ContextMenu>
                </Ellipse>
                <TextBlock Text="Н1" Foreground="#FFF" FontWeight="Bold" Canvas.Left="573" Canvas.Top="235"/>
            </Canvas>

            <Canvas x:Name="OzernaCanvas" Visibility="Collapsed">
                <TextBlock Text="СТАНЦІЯ ОЗЕРНА" Foreground="#334155" FontSize="32" FontWeight="Bold" Canvas.Left="20" Canvas.Top="20"/>
                <Line X1="50" Y1="300" X2="900" Y2="300" Stroke="#475569" StrokeThickness="10"/>
                <TextBlock Text="1П (Головна)" Foreground="#64748b" FontSize="14" FontWeight="Bold" Canvas.Left="650" Canvas.Top="315"/>
                <Line X1="400" Y1="180" X2="900" Y2="180" Stroke="#475569" StrokeThickness="10"/>
                <TextBlock Text="2П (Бокова)" Foreground="#64748b" FontSize="14" FontWeight="Bold" Canvas.Left="650" Canvas.Top="150"/>
                <Line X1="905" Y1="285" X2="905" Y2="315" Stroke="#dc2626" StrokeThickness="6"/>
                <Line X1="905" Y1="165" X2="905" Y2="195" Stroke="#dc2626" StrokeThickness="6"/>
                <Line X1="300" Y1="300" X2="400" Y2="180" Stroke="#475569" StrokeThickness="10"/>
                <Line x:Name="OzernaSwitch1" X1="300" Y1="300" X2="400" Y2="300" Stroke="#e2e8f0" StrokeThickness="10" Cursor="Hand" MouseLeftButtonDown="OzernaSwitch_Click" MouseRightButtonDown="Switch_RightClick"/>
                <TextBlock Text="1" Foreground="#FFF" FontWeight="Bold" Canvas.Left="340" Canvas.Top="320"/>
                
                <Line X1="180" Y1="310" X2="180" Y2="350" Stroke="#64748b" StrokeThickness="4"/>
                <Ellipse x:Name="SignalN" Canvas.Left="170" Canvas.Top="300" Width="20" Height="20" Fill="Red" Stroke="#0f172a" StrokeThickness="3" Cursor="Hand" MouseLeftButtonDown="Signal_Click">
                    <Ellipse.ContextMenu><ContextMenu><MenuItem Header="Зелений (на 1П)" Click="SignalN_SetGreen"/><MenuItem Header="Жовтий (на 2П)" Click="SignalN_SetYellow"/><MenuItem Header="Червоний" Click="SignalN_SetRed"/></ContextMenu></Ellipse.ContextMenu>
                </Ellipse>
                <TextBlock Text="Н" Foreground="#FFF" FontWeight="Bold" Canvas.Left="175" Canvas.Top="355"/>
                
                <Line X1="470" Y1="310" X2="470" Y2="350" Stroke="#64748b" StrokeThickness="4"/>
                <Ellipse x:Name="SignalCh1" Canvas.Left="460" Canvas.Top="300" Width="20" Height="20" Fill="Red" Stroke="#0f172a" StrokeThickness="3" Cursor="Hand" MouseLeftButtonDown="Signal_Click">
                    <Ellipse.ContextMenu><ContextMenu><MenuItem Header="Відкрити" Click="SignalCh1_SetGreen"/><MenuItem Header="Перекрити" Click="SignalCh1_SetRed"/></ContextMenu></Ellipse.ContextMenu>
                </Ellipse>
                <TextBlock Text="Ч1" Foreground="#FFF" FontWeight="Bold" Canvas.Left="463" Canvas.Top="355"/>

                <Line X1="470" Y1="190" X2="470" Y2="230" Stroke="#64748b" StrokeThickness="4"/>
                <Ellipse x:Name="SignalCh2" Canvas.Left="460" Canvas.Top="180" Width="20" Height="20" Fill="Red" Stroke="#0f172a" StrokeThickness="3" Cursor="Hand" MouseLeftButtonDown="Signal_Click">
                    <Ellipse.ContextMenu><ContextMenu><MenuItem Header="Відкрити" Click="SignalCh2_SetGreen"/><MenuItem Header="Перекрити" Click="SignalCh2_SetRed"/></ContextMenu></Ellipse.ContextMenu>
                </Ellipse>
                <TextBlock Text="Ч2" Foreground="#FFF" FontWeight="Bold" Canvas.Left="463" Canvas.Top="235"/>
            </Canvas>

            <Canvas IsHitTestVisible="True" Panel.ZIndex="5">
                <Grid x:Name="TrainGrid1" Width="72" Height="26" Visibility="Hidden" Cursor="Hand" MouseLeftButtonDown="Train_Click">
                    <Rectangle Fill="#3b82f6" Stroke="#0284c7" StrokeThickness="2" RadiusX="4" RadiusY="4">
                        <Rectangle.Effect><DropShadowEffect Color="#3b82f6" BlurRadius="15" ShadowDepth="0"/></Rectangle.Effect>
                    </Rectangle>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock x:Name="TrainDir1" Text="▶" Foreground="White" FontSize="11" Margin="0,0,4,0"/>
                        <TextBlock x:Name="TrainNum1" Text="№531" Foreground="White" FontWeight="Bold" FontSize="12"/>
                    </StackPanel>
                    <Grid.ContextMenu>
                        <ContextMenu Background="#111" Foreground="White">
                            <MenuItem Header="Відкрити Інфо-панель" Click="MenuInfo1_Click"/>
                            <MenuItem Header="Рух / Зупинка" Click="MenuMove1_Click"/>
                            <MenuItem Header="Зміна кабіни (Реверс)" Click="MenuReverse1_Click"/>
                            <Separator/>
                            <MenuItem Header="Зняти з дільниці" Click="MenuDelete1_Click"/>
                        </ContextMenu>
                    </Grid.ContextMenu>
                </Grid>

                <Grid x:Name="TrainGrid2" Width="72" Height="26" Visibility="Hidden" Cursor="Hand" MouseLeftButtonDown="Train_Click">
                    <Rectangle Fill="#f97316" Stroke="#c2410c" StrokeThickness="2" RadiusX="4" RadiusY="4">
                        <Rectangle.Effect><DropShadowEffect Color="#f97316" BlurRadius="15" ShadowDepth="0"/></Rectangle.Effect>
                    </Rectangle>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock x:Name="TrainDir2" Text="▶" Foreground="White" FontSize="11" Margin="0,0,4,0"/>
                        <TextBlock x:Name="TrainNum2" Text="№532" Foreground="White" FontWeight="Bold" FontSize="12"/>
                    </StackPanel>
                    <Grid.ContextMenu>
                        <ContextMenu Background="#111" Foreground="White">
                            <MenuItem Header="Відкрити Інфо-панель" Click="MenuInfo2_Click"/>
                            <MenuItem Header="Рух / Зупинка" Click="MenuMove2_Click"/>
                            <MenuItem Header="Зміна кабіни (Реверс)" Click="MenuReverse2_Click"/>
                            <Separator/>
                            <MenuItem Header="Зняти з дільниці" Click="MenuDelete2_Click"/>
                        </ContextMenu>
                    </Grid.ContextMenu>
                </Grid>
            </Canvas>

            <Border x:Name="InfoPopup" Visibility="Collapsed" Background="#0f172a" BorderBrush="#38bdf8" BorderThickness="2" CornerRadius="12" Width="360" Height="240" HorizontalAlignment="Center" VerticalAlignment="Center" Panel.ZIndex="100">
                <Border.Effect><DropShadowEffect Color="#38bdf8" BlurRadius="25" ShadowDepth="0" Opacity="0.5"/></Border.Effect>
                <StackPanel Margin="0">
                    
                    <Border Background="#38bdf8" CornerRadius="10,10,0,0" Padding="15,8">
                        <Grid>
                            <TextBlock Text="БОРТОВИЙ ТЕРМІНАЛ ЕЦ" Foreground="#0f172a" FontWeight="Bold" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Button Content="✖" Width="26" Height="26" HorizontalAlignment="Right" VerticalAlignment="Center" Background="Transparent" Foreground="#0f172a" BorderThickness="0" FontWeight="Bold" FontSize="16" Cursor="Hand" Click="BtnCloseInfo_Click"/>
                        </Grid>
                    </Border>
                    
                    <StackPanel Margin="20,15,20,20">
                        <TextBlock x:Name="InfoTitle" Text="Поїзд №531" Foreground="White" FontSize="24" FontWeight="Bold" Margin="0,0,0,15"/>
                        
                        <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Text="Локомотив:" Foreground="#94a3b8" FontSize="14" Grid.Column="0"/>
                            <TextBlock x:Name="InfoLoco" Text="ТУ2" Foreground="White" FontSize="14" FontWeight="Bold" Grid.Column="1"/>
                        </Grid>
                        <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Text="Машиніст:" Foreground="#94a3b8" FontSize="14" Grid.Column="0"/>
                            <TextBlock Text="Прус В." Foreground="White" FontSize="14" FontWeight="Bold" Grid.Column="1"/>
                        </Grid>
                        <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Text="Локація:" Foreground="#94a3b8" FontSize="14" Grid.Column="0"/>
                            <TextBlock x:Name="InfoStation" Text="ст. Центральна" Foreground="#38bdf8" FontSize="14" FontWeight="Bold" Grid.Column="1"/>
                        </Grid>
                        <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Text="Напрямок:" Foreground="#94a3b8" FontSize="14" Grid.Column="0"/>
                            <TextBlock x:Name="InfoDirection" Text="Вправо" Foreground="White" FontSize="14" FontWeight="Bold" Grid.Column="1"/>
                        </Grid>

                        <Border Background="#1e293b" CornerRadius="6" Padding="10" Margin="0,15,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="auto"/></Grid.ColumnDefinitions>
                                <TextBlock Text="СТАТУС:" Foreground="#94a3b8" FontSize="14" VerticalAlignment="Center" Grid.Column="0"/>
                                <TextBlock x:Name="InfoState" Text="◉ У РУСІ" Foreground="#10b981" FontSize="16" FontWeight="Bold" Grid.Column="1"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </Border>

        </Grid>
    </Grid>
</Window>