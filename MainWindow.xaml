<Window x:Class="DncApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="АРМ ДНЦ - Рівненська дитяча залізниця (Тренажер)" Height="720" Width="1150"
        Background="#0A0A0C">
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#1C1C1E" BorderBrush="#333" BorderThickness="0,0,2,0" Panel.ZIndex="10">
            <StackPanel>
                
                <StackPanel Margin="15,15,15,10">
                    <TextBlock Text="ПУЛЬТ ДНЦ (МПЦ)" Foreground="#AAAAAA" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                    <Button x:Name="BtnStationCentral" Content="ст. ЦЕНТРАЛЬНА" Height="35" Margin="0,0,0,5" Background="#333" Foreground="White" BorderThickness="0" Click="SwitchStation_Click"/>
                    <Button x:Name="BtnStationOzerna" Content="ст. ОЗЕРНА" Height="35" Margin="0,0,0,15" Background="#222" Foreground="Gray" BorderThickness="0" Click="SwitchStation_Click"/>
                    
                    <Button Content="АВАРІЙНЕ ПЕРЕКРИТТЯ СИГНАЛІВ" Height="40" Background="#B71C1C" Foreground="White" FontWeight="Bold" BorderThickness="0" Click="BtnEmergencyStop_Click"/>

                    <TextBlock Text="ЖУРНАЛ ДНЦ:" Foreground="#888" FontSize="11" Margin="0,15,0,5"/>
                    <ListBox x:Name="LogListBox" Height="250" Background="#000" Foreground="#00FF00" FontFamily="Consolas" FontSize="10" BorderBrush="#333"/>
                </StackPanel>

                <Separator Background="#444" Margin="10,0"/>

                <StackPanel Margin="15,10,15,15" Background="#252528">
                    <TextBlock Text="ВВЕДЕННЯ ПОЇЗДІВ" Foreground="#64B5F6" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,10,0,10"/>
                    <TextBlock Text="Керування рухом здійснюється кліком&#10;по самому поїзду на мнемосхемі." Foreground="#888" FontSize="11" TextAlignment="Center" Margin="0,0,0,10"/>
                    
                    <Button Content="+ НА ЦЕНТРАЛЬНУ" Height="30" Margin="10,0,10,5" Background="#444" Foreground="White" BorderThickness="0" Click="BtnAddTrainCentral_Click"/>
                    <Button Content="+ НА ОЗЕРНУ" Height="30" Margin="10,0,10,10" Background="#444" Foreground="White" BorderThickness="0" Click="BtnAddTrainOzerna_Click"/>
                </StackPanel>

            </StackPanel>
        </Border>

        <Grid Grid.Column="1" Margin="20">
            
            <Canvas x:Name="CentralCanvas" Visibility="Visible">
                <TextBlock Text="СТАНЦІЯ ЦЕНТРАЛЬНА" Foreground="#444" FontSize="24" FontWeight="Bold" Canvas.Left="20" Canvas.Top="20"/>
                <Line X1="45" Y1="285" X2="45" Y2="315" Stroke="Red" StrokeThickness="6"/>
                <Line X1="45" Y1="165" X2="45" Y2="195" Stroke="Red" StrokeThickness="6"/>
                <Line X1="50" Y1="300" X2="700" Y2="300" Stroke="#555" StrokeThickness="10"/>
                <TextBlock Text="1П" Foreground="#888" FontSize="14" FontWeight="Bold" Canvas.Left="350" Canvas.Top="315"/>
                <Line X1="50" Y1="180" X2="600" Y2="180" Stroke="#555" StrokeThickness="10"/>
                <TextBlock Text="2П" Foreground="#888" FontSize="14" FontWeight="Bold" Canvas.Left="350" Canvas.Top="150"/>
                <Line X1="600" Y1="180" X2="700" Y2="300" Stroke="#555" StrokeThickness="10"/>
                <Line x:Name="CentralSwitch" X1="700" Y1="300" X2="800" Y2="300" Stroke="#DDD" StrokeThickness="10" Cursor="Hand" MouseLeftButtonDown="CentralSwitch_Click" MouseRightButtonDown="Switch_RightClick"/>
                <TextBlock Text="1" Foreground="#FFF" FontWeight="Bold" Canvas.Left="750" Canvas.Top="320"/>
                <Line X1="800" Y1="300" X2="950" Y2="300" Stroke="#555" StrokeThickness="10"/>
                <Line X1="830" Y1="310" X2="830" Y2="350" Stroke="#888" StrokeThickness="4"/>
                <Ellipse x:Name="SignalCentralCh" Canvas.Left="820" Canvas.Top="300" Width="20" Height="20" Fill="Red" Stroke="#222" StrokeThickness="2" Cursor="Hand" MouseLeftButtonDown="Signal_Click">
                    <Ellipse.ContextMenu><ContextMenu><MenuItem Header="Зелений (на 1П)" Click="SignalCentralCh_SetGreen"/><MenuItem Header="Жовтий (на 2П)" Click="SignalCentralCh_SetYellow"/><MenuItem Header="Перекрити" Click="SignalCentralCh_SetRed"/></ContextMenu></Ellipse.ContextMenu>
                </Ellipse>
                <TextBlock Text="Ч" Foreground="#FFF" FontWeight="Bold" Canvas.Left="825" Canvas.Top="355"/>
                <Line X1="680" Y1="310" X2="680" Y2="350" Stroke="#888" StrokeThickness="4"/>
                <Ellipse x:Name="SignalCentralN1" Canvas.Left="670" Canvas.Top="300" Width="20" Height="20" Fill="Red" Stroke="#222" StrokeThickness="2" Cursor="Hand" MouseLeftButtonDown="Signal_Click">
                    <Ellipse.ContextMenu><ContextMenu><MenuItem Header="Відкрити" Click="SignalCentralN1_SetGreen"/><MenuItem Header="Перекрити" Click="SignalCentralN1_SetRed"/></ContextMenu></Ellipse.ContextMenu>
                </Ellipse>
                <TextBlock Text="Н1" Foreground="#FFF" FontWeight="Bold" Canvas.Left="673" Canvas.Top="355"/>
                <Line X1="580" Y1="190" X2="580" Y2="230" Stroke="#888" StrokeThickness="4"/>
                <Ellipse x:Name="SignalCentralN2" Canvas.Left="570" Canvas.Top="180" Width="20" Height="20" Fill="Red" Stroke="#222" StrokeThickness="2" Cursor="Hand" MouseLeftButtonDown="Signal_Click">
                    <Ellipse.ContextMenu><ContextMenu><MenuItem Header="Відкрити" Click="SignalCentralN2_SetGreen"/><MenuItem Header="Перекрити" Click="SignalCentralN2_SetRed"/></ContextMenu></Ellipse.ContextMenu>
                </Ellipse>
                <TextBlock Text="Н2" Foreground="#FFF" FontWeight="Bold" Canvas.Left="573" Canvas.Top="235"/>
            </Canvas>

            <Canvas x:Name="OzernaCanvas" Visibility="Collapsed">
                <TextBlock Text="СТАНЦІЯ ОЗЕРНА" Foreground="#444" FontSize="24" FontWeight="Bold" Canvas.Left="20" Canvas.Top="20"/>
                <Line X1="50" Y1="300" X2="900" Y2="300" Stroke="#555" StrokeThickness="10"/>
                <TextBlock Text="1П" Foreground="#888" FontSize="14" FontWeight="Bold" Canvas.Left="650" Canvas.Top="315"/>
                <Line X1="400" Y1="180" X2="900" Y2="180" Stroke="#555" StrokeThickness="10"/>
                <TextBlock Text="2П" Foreground="#888" FontSize="14" FontWeight="Bold" Canvas.Left="650" Canvas.Top="150"/>
                <Line X1="905" Y1="285" X2="905" Y2="315" Stroke="Red" StrokeThickness="6"/>
                <Line X1="905" Y1="165" X2="905" Y2="195" Stroke="Red" StrokeThickness="6"/>
                <Line X1="300" Y1="300" X2="400" Y2="180" Stroke="#555" StrokeThickness="10"/>
                <Line x:Name="OzernaSwitch1" X1="300" Y1="300" X2="400" Y2="300" Stroke="#DDD" StrokeThickness="10" Cursor="Hand" MouseLeftButtonDown="OzernaSwitch_Click" MouseRightButtonDown="Switch_RightClick"/>
                <TextBlock Text="1" Foreground="#FFF" FontWeight="Bold" Canvas.Left="340" Canvas.Top="320"/>
                <Line X1="180" Y1="310" X2="180" Y2="350" Stroke="#888" StrokeThickness="4"/>
                <Ellipse x:Name="SignalN" Canvas.Left="170" Canvas.Top="300" Width="20" Height="20" Fill="Red" Stroke="#222" StrokeThickness="2" Cursor="Hand" MouseLeftButtonDown="Signal_Click">
                    <Ellipse.ContextMenu><ContextMenu><MenuItem Header="Зелений (на 1П)" Click="SignalN_SetGreen"/><MenuItem Header="Жовтий (на 2П)" Click="SignalN_SetYellow"/><MenuItem Header="Червоний (закрито)" Click="SignalN_SetRed"/></ContextMenu></Ellipse.ContextMenu>
                </Ellipse>
                <TextBlock Text="Н" Foreground="#FFF" FontWeight="Bold" Canvas.Left="175" Canvas.Top="355"/>
                <Line X1="470" Y1="310" X2="470" Y2="350" Stroke="#888" StrokeThickness="4"/>
                <Ellipse x:Name="SignalCh1" Canvas.Left="460" Canvas.Top="300" Width="20" Height="20" Fill="Red" Stroke="#222" StrokeThickness="2" Cursor="Hand" MouseLeftButtonDown="Signal_Click">
                    <Ellipse.ContextMenu><ContextMenu><MenuItem Header="Відкрити" Click="SignalCh1_SetGreen"/><MenuItem Header="Перекрити" Click="SignalCh1_SetRed"/></ContextMenu></Ellipse.ContextMenu>
                </Ellipse>
                <TextBlock Text="Ч1" Foreground="#FFF" FontWeight="Bold" Canvas.Left="463" Canvas.Top="355"/>
            </Canvas>

            <Canvas IsHitTestVisible="True" Panel.ZIndex="5">
                <Rectangle x:Name="TrainVisual1" Width="50" Height="20" Fill="#2196F3" Stroke="#0D47A1" StrokeThickness="2" RadiusX="4" RadiusY="4" Visibility="Hidden" Canvas.Top="290" Cursor="Hand" MouseLeftButtonDown="Train_Click">
                    <Rectangle.Effect><DropShadowEffect Color="#2196F3" BlurRadius="15" ShadowDepth="0"/></Rectangle.Effect>
                    <Rectangle.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Інформація про поїзд" Click="MenuInfo1_Click"/>
                            <MenuItem Header="Почати / Зупинити рух" Click="MenuMove1_Click"/>
                            <MenuItem Header="Зміна кабіни (Реверс)" Click="MenuReverse1_Click"/>
                            <Separator/>
                            <MenuItem Header="Зняти з дільниці" Click="MenuDelete1_Click"/>
                        </ContextMenu>
                    </Rectangle.ContextMenu>
                </Rectangle>
                <TextBlock x:Name="TrainLabel1" Text="№" Foreground="Yellow" FontSize="11" FontWeight="Bold" Visibility="Hidden" Canvas.Top="270" IsHitTestVisible="False"/>

                <Rectangle x:Name="TrainVisual2" Width="50" Height="20" Fill="#FF5722" Stroke="#B71C1C" StrokeThickness="2" RadiusX="4" RadiusY="4" Visibility="Hidden" Canvas.Top="290" Cursor="Hand" MouseLeftButtonDown="Train_Click">
                    <Rectangle.Effect><DropShadowEffect Color="#FF5722" BlurRadius="15" ShadowDepth="0"/></Rectangle.Effect>
                    <Rectangle.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Інформація про поїзд" Click="MenuInfo2_Click"/>
                            <MenuItem Header="Почати / Зупинити рух" Click="MenuMove2_Click"/>
                            <MenuItem Header="Зміна кабіни (Реверс)" Click="MenuReverse2_Click"/>
                            <Separator/>
                            <MenuItem Header="Зняти з дільниці" Click="MenuDelete2_Click"/>
                        </ContextMenu>
                    </Rectangle.ContextMenu>
                </Rectangle>
                <TextBlock x:Name="TrainLabel2" Text="№" Foreground="Yellow" FontSize="11" FontWeight="Bold" Visibility="Hidden" Canvas.Top="270" IsHitTestVisible="False"/>
            </Canvas>
        </Grid>
    </Grid>
</Window>